e code generated by <ac:link><ri:user ri:account-id=\"000000000000000000000000\" ri:local-id=\"f2eff831-a9c5-4404-8d35-631e0365def6\" /></ac:link> 's Claude:</h3><ac:structured-macro ac:name=\"code\" ac:schema-version=\"1\" ac:local-id=\"1af89b1142e2\" ac:macro-id=\"d0ff3acf-13c4-4c5b-be92-f0b94d61efd0\"><ac:parameter ac:name=\"breakoutMode\">wide</ac:parameter><ac:parameter ac:name=\"breakoutWidth\">760</ac:parameter><ac:plain-text-body><![CDATA[def gcd(a: int, b: int) -> int:\n    while b:\n        a, b = b, a % b\n    return a\n\n\ndef lcm(a: int, b: int) -> int:\n    return abs(a * b) // gcd(a, b)\n\n\ndef least_common_denominator(denominators: list[int]) -> int:\n    result = 1\n    for d in denominators:\n        result = lcm(result, d)\n    return result]]></ac:plain-text-body></ac:structured-macro><ac:task-list ac:task-list-id=\"c48a8292-d4d6-44c0-8940-77ee6b05ff15\">\n<ac:task>\n<ac:task-id>1</ac:task-id>\n<ac:task-uuid>6a0e3823-e9f0-4049-9d48-029dcf59d3de</ac:task-uuid>\n<ac:task-status>incomplete</ac:task-status>\n<ac:task-body><span class=\"placeholder-inline-tasks\">Add task list</span></ac:task-body>\n</ac:task>\n<ac:task>\n<ac:task-id>2</ac:task-id>\n<ac:task-uuid>f92e416c-8d75-466e-93d4-8c45f5ac90f7</ac:task-uuid>\n<ac:task-status>complete</ac:task-status>\n<ac:task-body><span class=\"placeholder-inline-tasks\">Add web image</span></ac:task-body>\n</ac:task>\n<ac:task>\n<ac:task-id>3</ac:task-id>\n<ac:task-uuid>a065efd1-ae88-4a2f-8f77-8c592f2c0098</ac:task-uuid>\n<ac:task-status>incomplete</ac:task-status>\n<ac:task-body><span class=\"placeholder-inline-tasks\">Add macro in table</span></ac:task-body>\n</ac:task>\n</ac:task-list><table data-table-width=\"760\" data-layout=\"default\" ac:local-id=\"d4ae51157756\"><tbody><tr ac:local-id=\"c1c5e357ebf1\"><th ac:local-id=\"78a65521cd80\"><p local-id=\"0337061a2aa3\"><strong>Velocity</strong></p></th><th ac:local-id=\"081d23facf1d\"><p local-id=\"af11c3975f93\"><strong>Mass</strong></p></th><th ac:local-i